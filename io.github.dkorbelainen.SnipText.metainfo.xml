<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.dkorbelainen.SnipText</id>
  <name>SnipText</name>
  <summary>Screen capture OCR tool</summary>
  <metadata_license>MIT</metadata_license>
  <project_license>MIT</project_license>

  <description>
    <p>
      SnipText is a lightweight screen capture and OCR tool for Linux. Trigger a hotkey,
      select a region, and the recognized text is instantly copied to your clipboard.
    </p>
    <p>Features:</p>
    <ul>
      <li>Region selection with slurp (Wayland) or similar tools</li>
      <li>Tesseract OCR with ensemble recognition</li>
      <li>Configurable hotkeys</li>
      <li>Optional scikit-learn confidence calibration</li>
      <li>Wayland and X11 support</li>
    </ul>
  </description>

  <launchable type="desktop-id">io.github.dkorbelainen.SnipText.desktop</launchable>

  <url type="homepage">https://github.com/dkorbelainen/sniptext</url>
  <url type="bugtracker">https://github.com/dkorbelainen/sniptext/issues</url>

  <developer id="io.github.dkorbelainen">
    <name>dkorbelainen</name>
  </developer>

  <content_rating type="oars-1.1"/>

  <releases>
    <release version="0.4.0" date="2025-06-07">
      <description>
        <p>Confidence calibration with per-engine scikit-learn models.</p>
      </description>
    </release>
  </releases>

  <categories>
    <category>Utility</category>
    <category>Graphics</category>
  </categories>

  <keywords>
    <keyword>ocr</keyword>
    <keyword>screenshot</keyword>
    <keyword>text</keyword>
    <keyword>capture</keyword>
    <keyword>tesseract</keyword>
    <keyword>wayland</keyword>
  </keywords>
</component>
