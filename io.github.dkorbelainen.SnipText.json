{
  "app-id": "io.github.dkorbelainen.SnipText",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "23.08",
  "sdk": "org.freedesktop.Sdk",
  "command": "sniptext",
  "finish-args": [
    "--share=ipc",
    "--socket=wayland",
    "--socket=fallback-x11",
    "--device=dri",
    "--env=TESSDATA_PREFIX=/app/share/tessdata"
  ],
  "modules": [
    {
      "name": "leptonica",
      "buildsystem": "cmake-ninja",
      "builddir": true,
      "config-opts": [
        "-DCMAKE_INSTALL_PREFIX=/app",
        "-DBUILD_SHARED_LIBS=ON"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://github.com/DanBloomberg/leptonica/releases/download/1.84.1/leptonica-1.84.1.tar.gz",
          "sha256": "2b3e1254b1cca381e77c819b59ca99774ff43530209b9aeb511e1d46588a64f6"
        }
      ]
    },
    {
      "name": "tesseract",
      "buildsystem": "cmake-ninja",
      "builddir": true,
      "config-opts": [
        "-DCMAKE_INSTALL_PREFIX=/app",
        "-DBUILD_SHARED_LIBS=ON",
        "-DBUILD_TRAINING_TOOLS=OFF",
        "-DDISABLE_TIFF=ON"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://github.com/tesseract-ocr/tesseract/archive/refs/tags/5.5.0.tar.gz",
          "sha256": "f2fb34ca035b6d087a42875a35a7a5c4155fa9979c6132365b1e5a28ebc3fc11"
        }
      ]
    },
    {
      "name": "tessdata",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm644 eng.traineddata /app/share/tessdata/eng.traineddata"
      ],
      "sources": [
        {
          "type": "file",
          "url": "https://github.com/tesseract-ocr/tessdata_fast/raw/main/eng.traineddata",
          "sha256": "7d4322bd2a7749724879683fc3912cb542f19906c83bcc1a52132556427170b2",
          "dest-filename": "eng.traineddata"
        }
      ]
    },
    {
      "name": "wl-clipboard",
      "buildsystem": "meson",
      "builddir": true,
      "config-opts": [
        "--prefix=/app",
        "-Dfishcompletiondir=no"
